{
  "pykeVersion": "0.3.0",
  "name": "c++_project",
  "type": "c++",
  "version": "0.0.0",
  "+ dependsOn": [],
  "outputType": "exe",
  "multithreaded": true,
  "wholeProgram": false,
  "wholeOpt": false,
  "+ includeDirs": ["%{projectDir}/inc"],
  "useStdIncludeDirs": true,
  "sourceDir": "%{projectDir}/src",
  "resourceDir": "%{projectDir}/res",
  "+ libDirs": [],
  "intermediateDir": "%{projectDir}/obj",
  "outputDir": "%{projectDir}/bin",
  "outputPath": "%{outputDir}/%{outputName}",
  "editionMarker": "",
  "+ sources": [],
  "+ resources": [],
  "+ packages": [],
  "+ libs": [],
  "+ usageGroupDefaults": [
    "platform:linux-gnu"
  ],
  "--linux-gnu:platform": {
    "toolSet": "CPlusPlusLinuxGnu",
    "objFileExtension": "o",
    "preprocessTool": "cpp",
    "compileTool": "g++",
    "archiveTool": "ar",
    "linkTool": "g++",
    "wholeBuildTool": "g++",
    "compileOutputName": "%{c++Src}%{editionMark}.%{objFileExtension}",
    "compileOutputPath": "%{intermediateDir}/%{compileOutputName}",
    "compileSoOutputPath": "%{compileOutputPath}",
    "compileSExeutputPath": "%{compileOutputPath}",
    "resolveIncludesCmds": [
      "%{preprocessTool} -M %{useStd} %{includeDirsArg} %{packagesInclude} %{srcPath}"
    ],
    "compileCmds": [      
      "%{compileTool} %{useStd} %{compileArgs} %[c++Src] %{includeDirsArg} %{packagesInclude} -o %{outputPath} %{srcPath}"
    ],
    "archiveCmds": [
      "%{archiveTool} %{arArgs} -o %{outputPath} %{objFilePathsArg}"
    ],
    "linkCmds": [      
      "%{linkTool} %{useStd} %{linkArgs} -o %{outputPath} %{objFilePathsArg} %{packagesLink} %{libsArg} %{libDirsArg}"
    ],
    "wholeBuildCmds": [
      "%{wholeBuildTool} %{useStd} %{wholeBuildArgs} %{includeDirsArg} %{packagesInclude} -o %{outputPath} %{objFilePathsArg} %{packagesLink} %{libsArg} %{libDirsArg}"
    ],
    "compileLibCmds": "%[compileCmds]",
    "archiveLibCmds": "%[archiveCmds]",
    "compileSoCmds": "%[compileCmds]",
    "linkeSoCmds": "%[linkCmds]",
    "compileExeCmds": "%[compileCmds]",
    "linkeExeCmds": "%[linkCmds]",
    "buildLibPlan": [ {
        "systemCmds": [
          "%[compileLibCmds]"
        ],
        "depChecks": [ {
            "target": "%{compileLibOutputPath}",
            "deps": [
              "%[c++Src]"
            ]
        } ]
      }, {
        "systemCmds": [
          "%{archiveCmds}"
        ],
        "depChecks": [ {
          "target": "%{outputPath}",
          "deps": [
            "%{compileLibOutputPath}"
          ]
        } ]
      }
    ],
    "buildSoPlan": [ {
        "systemCmds": [
          "%[compileSoCmds]"
        ],
        "depChecks": [ {
            "target": "%{compileSoOutputPath}",
            "deps": [
              "%[c++Src]"
            ]
        } ]
      }, {
        "systemCmds": [
          "%[linkSoCmds]"
        ],
        "depChecks": [ {
          "target": "%{outputPath}",
          "deps": [
            "%{compileSoOutputPath}"
          ]
        } ]
      }
    ],
    "buildExePlan": [ {
        "systemCmds": [
          "%[compileExeCmds]"
        ],
        "depChecks": [ {
            "target": "%{compileExeOutputPath}",
            "deps": [
              "%[c++Src]"
            ]
        } ]
      }, {
        "systemCmds": [
          "%[linkExeCmds]"
        ],
        "depChecks": [ {
          "target": "%{outputPath}",
          "deps": [
            "%{compileExeOutputPath}"
          ]
        } ]
      }
    ],
    "+ compileArgs": [
      "-Wall",
      "-c"
    ],
    "+ linkArgs": ["-Wall"],
    "+ wholeBuildArgs": ["-Wall"],
    "+ usageGropuDefaults": [
      "c++Std:c++14",
      "kind:exe",
      "edition:debug"
    ],
    "--c++11|11:c++Std": {
      "use-std": "c++11"
    },
    "--c++14|14:c++Std": {
      "use-std": "c++14"
    },
    "--c++17|17:c++Std": {
      "use-std": "c++17"
    },
    "--lib|l:kind": {
      "outputType": "lib",
      "outputName": "lib%{name}%{editionMark}.a",
      "+ arArgs": "cvq",
      "buildPlan": [
        "%[buildLibPlan]"
      ]
    },
    "--so|s:kind": {
      "outputType": "so",
      "outputName": "lib%{name}%{editionMark}.so.%{versionMajor}.%{versionMinor}",
      "+ compileArgs": [
        "-fPIC"
      ],
      "+ linkArgs": [
        "-shared",
        "-Wl,soname,%{soname}"
      ],
      "+ wholeBuildArgs": [
        "-fPIC",
        "-shared",
        "-Wl,soname,%{soname}"
      ],
      "buildPlan": [
        "%[buildSoPlan]"
      ]
    },
    "--exe|e:kind": {
      "outputType": "exe",
      "outputName": "%{name}%{editionMark}",
      "buildPlan": [
        "%[buildExePlan]"
      ],
      "! run|r": {
        "doc": {
          "short": "Run the resulting executable.",
          "long": "Runs the built executable in place, making sure to properly reference any dependent libraries."
        }
      }
    },
    "--wholeProgram|wp": {
      "compileSoCmds": "%[wholeBuildCmds]",
      "compileSoOutputPath": "%{outputPath}",
      "compileExeCmds": "%[wholeBuildCmds]",
      "compileSExeutputPath": "%{outputPath}",
      "buildSoPlan": [ {
          "systemCmds": [
              "%[compileSoCmds]"
            ],
            "depChecks": [ {
                "target": "%{compileSoOutputPath}",
                "deps": [
                  "%[c++Src]"
                ]
            } ]
      } ],
      "buildExePlan": [ {
          "systemCmds": [
            "%[compileExeCmds]"
          ],
          "depChecks": [ {
              "target": "%{compileExeOutputPath}",
              "deps": [
                "%[c++Src]"
              ]
          } ]
      } ]
    },
    "--debug|d:edition": {
      "edition": "debug",
      "outputDir": "%{projectDir}/bin/debug",
      "editionMark": ".d",
      "+ libDirs": [
        "%{projectDir}/bin/debug"
      ],
      "intermediateDir": "%{projectDir}/obj/debug",
      "+ compileArgs": [
        "-g",
        "-Og",
        "-fno-inline"
      ],
      "+ wholeBuildArgs": [
        "-g",
        "-Og",
        "-fno-inline"
      ]
    },
    "--release|r:edition": {
      "edition": "release",
      "outputDir": "%{projectDir}/bin/release",
      "editionMark": ".r",
      "+ libDirs": [
        "%{projectDir}/bin/release"
      ],
      "intermediateDir": "%{projectDir}/obj/release",
      "+ compileArgs": [
        "-DNDEBUG",
        "-O3"
      ],
      "+ wholeBuildArgs": [
        "-DNDEBUG",
        "-O3"
      ]
    }
  },
  "doc": {
    "short": "Defines a C++ project.",
    "long": "Defines the operations for building and maintaining a C++ project. The full suite of tools for building, deploying, and testing a C++ project can be found here."
  },
  "! clean|c": {
    "doc": {
      "short": "Clean the tree.",
      "long": "Deletes all intermediate files generated from the build. Essentially, put the tree into a fresh state."
    }
  },
  "! build|b": {
    "doc": {
      "short": "Build the project.",
      "long": "Build the C++ project, according to the json."
    }
  }
}
